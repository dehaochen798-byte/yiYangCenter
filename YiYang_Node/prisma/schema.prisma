generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "mysql"
}

enum Gender {
  MALE
  FEMALE
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum BedStatus {
  VACANT
  OCCUPIED
  DISABLED
}

enum ResidenceStatus {
  PENDING
  ACTIVE
  CHECKED_OUT
}

enum OutingStatus {
  PENDING
  OUTING
  RETURNED
}

enum ServiceFocusStatus {
  ACTIVE
  PAUSED
  ENDED
}

model User {
  id                Int             @id @default(autoincrement())
  mobile            String          @unique @db.VarChar(20)
  passwordHash      String
  realName          String          @db.VarChar(50)
  nickName          String          @db.VarChar(50)
  age               Int
  gender            Gender
  status            UserStatus      @default(ACTIVE)
  roleName          String?         @db.VarChar(50)
  departmentName    String?         @db.VarChar(50)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  residents         Resident[]
  managedTargets    ServiceTarget[] @relation("ServiceManager")
  careRecords       CareRecord[]
}

model Resident {
  id                    Int                @id @default(autoincrement())
  userId                Int?
  currentBedId          Int?               @unique
  careLevelId           Int?
  fullName              String             @db.VarChar(50)
  age                   Int
  gender                Gender
  phone                 String             @unique @db.VarChar(20)
  idCard                String?            @db.VarChar(30)
  emergencyContactName  String?            @db.VarChar(50)
  emergencyContactPhone String?            @db.VarChar(20)
  status                ResidenceStatus    @default(PENDING)
  note                  String?            @db.Text
  user                  User?              @relation(fields: [userId], references: [id])
  currentBed            Bed?               @relation("ResidentCurrentBed", fields: [currentBedId], references: [id])
  careLevel             CareLevel?         @relation(fields: [careLevelId], references: [id])
  checkIns              CheckIn[]
  checkOuts             CheckOut[]
  outings               Outing[]
  mealPlans             MealPlan[]
  serviceTargets        ServiceTarget[]
  serviceFocuses        ServiceFocus[]
  careRecords           CareRecord[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}

model Room {
  id          Int      @id @default(autoincrement())
  building    String?  @db.VarChar(50)
  roomNo      String   @unique @db.VarChar(30)
  floor       Int
  roomType    String?  @db.VarChar(50)
  bedCount    Int
  description String?  @db.VarChar(255)
  isActive    Boolean  @default(true)
  beds        Bed[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Bed {
  id            Int        @id @default(autoincrement())
  roomId        Int
  bedNo         String     @db.VarChar(30)
  label         String?    @db.VarChar(50)
  status        BedStatus  @default(VACANT)
  room          Room       @relation(fields: [roomId], references: [id])
  currentResident Resident? @relation("ResidentCurrentBed")
  checkIns      CheckIn[]
  checkOuts     CheckOut[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([roomId, bedNo])
}

model MealPlan {
  id                   Int      @id @default(autoincrement())
  residentId           Int
  title                String   @db.VarChar(100)
  description          String?  @db.Text
  dietaryRestrictions  String?  @db.VarChar(255)
  allergens            String?  @db.VarChar(255)
  nutritionTags        String?  @db.VarChar(255)
  startDate            DateTime?
  endDate              DateTime?
  resident             Resident @relation(fields: [residentId], references: [id])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model MealCalendar {
  id            Int      @id @default(autoincrement())
  campus        String?  @db.VarChar(50)
  weekLabel     String   @db.VarChar(50)
  weekStartDate DateTime
  monday        String?  @db.VarChar(255)
  tuesday       String?  @db.VarChar(255)
  wednesday     String?  @db.VarChar(255)
  thursday      String?  @db.VarChar(255)
  friday        String?  @db.VarChar(255)
  saturday      String?  @db.VarChar(255)
  sunday        String?  @db.VarChar(255)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CheckIn {
  id          Int      @id @default(autoincrement())
  residentId  Int
  bedId       Int
  checkInAt   DateTime
  note        String?  @db.Text
  resident    Resident @relation(fields: [residentId], references: [id])
  bed         Bed      @relation(fields: [bedId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CheckOut {
  id            Int      @id @default(autoincrement())
  residentId    Int
  bedId         Int?
  checkOutAt    DateTime
  reason        String?  @db.Text
  handoverNote  String?  @db.Text
  resident      Resident @relation(fields: [residentId], references: [id])
  bed           Bed?     @relation(fields: [bedId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Outing {
  id               Int          @id @default(autoincrement())
  residentId       Int
  startAt          DateTime
  expectedReturnAt DateTime?
  actualReturnAt   DateTime?
  destination      String?      @db.VarChar(255)
  reason           String?      @db.VarChar(255)
  status           OutingStatus @default(PENDING)
  resident         Resident     @relation(fields: [residentId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model ServiceTarget {
  id             Int      @id @default(autoincrement())
  residentId     Int
  managerUserId  Int?
  managerName    String   @db.VarChar(50)
  managerMobile  String   @db.VarChar(20)
  startDate      DateTime?
  endDate        DateTime?
  relationNote   String?  @db.Text
  resident       Resident @relation(fields: [residentId], references: [id])
  managerUser    User?    @relation("ServiceManager", fields: [managerUserId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ServiceFocus {
  id              Int                @id @default(autoincrement())
  residentId      Int
  serviceName     String             @db.VarChar(100)
  detail          String?            @db.Text
  serviceStartAt  DateTime?
  serviceEndAt    DateTime?
  status          ServiceFocusStatus @default(ACTIVE)
  resident        Resident           @relation(fields: [residentId], references: [id])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model CareLevel {
  id          Int        @id @default(autoincrement())
  code        String     @unique @db.VarChar(30)
  name        String     @unique @db.VarChar(50)
  description String?    @db.Text
  isActive    Boolean    @default(true)
  residents   Resident[]
  items       CareItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model CareItem {
  id              Int        @id @default(autoincrement())
  careLevelId     Int
  name            String     @db.VarChar(100)
  description     String?    @db.Text
  frequency       String?    @db.VarChar(50)
  durationMinutes Int?
  instructions    String?    @db.Text
  isActive        Boolean    @default(true)
  careLevel       CareLevel  @relation(fields: [careLevelId], references: [id])
  records         CareRecord[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model CareRecord {
  id          Int      @id @default(autoincrement())
  residentId  Int
  careItemId  Int
  operatorId  Int
  executedAt  DateTime
  note        String?  @db.Text
  resident    Resident @relation(fields: [residentId], references: [id])
  careItem    CareItem @relation(fields: [careItemId], references: [id])
  operator    User     @relation(fields: [operatorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
