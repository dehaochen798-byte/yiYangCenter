{
  "name": "yiyang-node",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "YiYang Center backend powered by NestJS and Prisma",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main.js",
    "start:gateway": "nest start",
    "start:gateway:dev": "nest start --watch",
    "start:service-auth": "node --loader ts-node/esm src/apps/service-auth/main.ts",
    "start:service-auth:dev": "node --watch --loader ts-node/esm src/apps/service-auth/main.ts",
    "start:service-care": "node --loader ts-node/esm src/apps/service-care/main.ts",
    "start:service-care:dev": "node --watch --loader ts-node/esm src/apps/service-care/main.ts",
    "start:message-consumer": "node --loader ts-node/esm src/apps/message-consumer/main.ts",
    "start:message-consumer:dev": "node --watch --loader ts-node/esm src/apps/message-consumer/main.ts",
    "test": "node --loader ts-node/esm --test \"test/**/*.spec.ts\"",
    "lint": "eslint \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"prisma/**/*.ts\" --fix",
    "format": "prettier . --write",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "node --loader ts-node/esm prisma/seed.ts",
    "generate:module": "node --loader ts-node/esm tools/generate-module.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/microservices": "^11.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.1",
    "@prisma/adapter-mariadb": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.2",
    "openai": "^6.45.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.30",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.6",
    "globals": "^16.1.0",
    "prettier": "^3.5.3",
    "prisma": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0"
  }
}
